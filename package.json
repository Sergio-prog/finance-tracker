{
  "name": "finance-tracker",
  "private": true,
  "description": "A modern, self-hosted personal finance tracker — track expenses, income, and subscriptions with beautiful charts and customizable themes.",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "seed": "bun run scripts/seed-transactions.ts",
    "seed:dry": "bun run scripts/seed-transactions.ts --dry-run",
    "db:generate": "drizzle-kit generate",
    "db:revert": "drizzle-kit drop",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "1.166.2",
    "@tanstack/react-start": "1.166.2",
    "@tanstack/router-plugin": "1.166.2",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "motion": "^12.40.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "recharts": "3.8.0",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
